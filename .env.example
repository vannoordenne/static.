# Copy this file to .env and fill in values locally. Never commit .env.
# See SECURITY.md before sharing this repository.
#
# Google Colab: skip .env — use Secrets instead (key icon, left sidebar):
#   HF_TOKEN = your Hugging Face token
#   IIA4XAI_OUTPUT_DIR = optional output folder (e.g. after mounting Drive)
#   IIA4XAI_PROMPT_FILE = optional prompt file path

# Hugging Face access token (required for Stable Diffusion v1-4 weights).
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Directory for webcam input, generated images, and CSV output.
# In Google Colab, mount Drive and set to your own folder, e.g.:
# IIA4XAI_OUTPUT_DIR=/content/drive/MyDrive/your-folder/imgs
IIA4XAI_OUTPUT_DIR=./output/imgs

# File where the latest CLIP Interrogator prompt is written for the display layer.
IIA4XAI_PROMPT_FILE=./output/prompt.txt
